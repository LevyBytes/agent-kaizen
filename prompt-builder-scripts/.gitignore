# Logs (a no-slash pattern matches at any depth, including subfolders)
*.log

# Python cache/build artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.pyright/
.hypothesis/
.tox/
.nox/
.eggs/
__pypackages__/
.ipynb_checkpoints/
.coverage
.coverage.*
coverage.xml
htmlcov/
build/
dist/
*.egg
*.egg-info/
pip-wheel-metadata/

# Local environment/config files
.env*
*.local
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# Secrets, credentials, and private key material
*.pem
*.key
*.p12
*.pfx
*.ppk
id_rsa*
id_ed25519*
*.kdbx
*.age
*.gpg
*.asc

# Private binary documents, archives, and local databases
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.zip
*.7z
*.rar
*.sqlite
*.sqlite3
*.db

# Editor/OS clutter
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
